{
  "name": "run-gmc",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify --outdir dist --upload-source-maps",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "coverflex-uat": "pnpm dlx tsx bin/coverflex-uat.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject dist && sentry-cli sourcemaps upload --org=gmcabrita-2q --project=run-gmc dist",
    "postdeploy": "pnpm sentry:sourcemaps"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.31.0",
    "hono": "^4.11.1",
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "@sentry/cli": "^2",
    "@types/node": "^25.0.3",
    "wrangler": "^4.55.0"
  }
}
