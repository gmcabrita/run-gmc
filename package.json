{
  "name": "run-gmc",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --minify --outdir dist --dry-run",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject dist && sentry-cli sourcemaps upload --org=goncalo-mendes-cabrita --project=run-gmc dist",
    "deploy": "pnpm build && pnpm sentry:sourcemaps && wrangler deploy dist/index.js --no-bundle --upload-source-maps",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "coverflex-uat": "pnpm dlx tsx bin/coverflex-uat.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.31.0",
    "feed": "^5.1.0",
    "hono": "^4.11.1",
    "worker-mailer": "^1.2.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.11.1",
    "@sentry/cli": "^2",
    "@types/node": "^25.0.3",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.55.0"
  }
}
