{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "baseUrl": ".",
    "paths": {
      "@email": ["src/email/index.ts"],
      "@email/*": ["src/email/*"],
      "@coverflex": ["src/coverflex/index.ts"],
      "@coverflex/*": ["src/coverflex/*"],
      "@x": ["src/x/index.ts"],
      "@x/*": ["src/x/*"],
      "@fetchToRss": ["src/fetchToRss/index.ts"],
      "@fetchToRss/*": ["src/fetchToRss/*"],
      "@rss": ["src/rss/scrapers.ts"],
      "@rss/*": ["src/rss/*"],
      "@types": ["src/types.ts"],
    },
  },
}
