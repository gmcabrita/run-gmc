{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "baseUrl": ".",
    "paths": {
      "@email": ["src/email/index.ts"],
      "@email/*": ["src/email/*"],
      "@coverflex": ["src/coverflex/index.ts"],
      "@coverflex/*": ["src/coverflex/*"],
    },
  },
}
